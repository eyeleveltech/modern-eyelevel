<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Block junk query strings like ?161df1950567902.html (not real pages)
  RewriteCond %{QUERY_STRING} ^[0-9a-f]{8,}\.html=?$ [NC]
  RewriteRule ^ - [R=410,L]

  # Optionally block query strings containing ".html" with no key=value params
  RewriteCond %{QUERY_STRING} \.html [NC]
  RewriteCond %{QUERY_STRING} ![=&] [NC]
  RewriteRule ^ - [R=410,L]

  # Server-side redirects (avoid client-only SPA redirects)
  RewriteRule ^how-we-work/?$ /about-us [R=301,L]
  RewriteRule ^terms-conditions/?$ /terms-and-condition [R=301,L]

  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Return a real 404 for unknown routes instead of serving SPA shell for everything.
  RewriteCond %{REQUEST_URI} !^/(?:$|about-us/?$|careers/?$|careers/[^/]+/?$|services/?$|industries/?$|contact-us/?$|blog/?$|blog/[^/]+/?$|booking/?$|apply/?$|thank-you/?$|terms-and-condition/?$|privacy-policy/?$) [NC]
  RewriteRule ^ - [R=404,L]

  RewriteRule ^ index.html [L]
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On

  # HTML should refresh quickly so users get the latest deployment.
  ExpiresByType text/html "access plus 0 seconds"

  # Static assets can be cached aggressively (hashed filenames in /assets).
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType text/javascript "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/avif "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType application/font-woff2 "access plus 1 year"
  ExpiresByType application/font-woff "access plus 1 year"
</IfModule>

<IfModule mod_headers.c>
  # Ensure HTML is revalidated quickly.
  <FilesMatch "^index\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>

  # Cache compiled/static files strongly.
  <FilesMatch "\.(?:css|js|mjs|png|jpg|jpeg|gif|webp|avif|svg|ico|woff|woff2)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>
